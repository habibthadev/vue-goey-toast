{
  "name": "vue-goey-toast",
  "version": "0.1.0",
  "description": "A gooey, morphing toast component for Vue 3, ported from goey-toast by anl331 (https://github.com/anl331/goey-toast)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm typecheck && pnpm format:check && pnpm lint && pnpm test && pnpm build",
    "prepare": "husky"
  },
  "peerDependencies": {
    "motion-v": ">=2.0.0",
    "vue": ">=3.4.0",
    "vue-sonner": ">=2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "motion": "^11.18.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.9",
    "vue": "^3.5.32",
    "vue-tsc": "^2.2.12"
  },
  "keywords": [
    "toast",
    "notification",
    "vue",
    "vue3",
    "animation",
    "morph",
    "gooey"
  ],
  "license": "MIT",
  "author": "Habib (habibthadev) — Vue port of goey-toast by anl331 (https://github.com/anl331/goey-toast)",
  "repository": {
    "type": "git",
    "url": "https://github.com/habibthadev/vue-goey-toast"
  },
  "homepage": "https://vue-goey-toast.vercel.app",
  "bugs": {
    "url": "https://github.com/habibthadev/vue-goey-toast/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
